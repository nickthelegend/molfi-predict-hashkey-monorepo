PORT=4000
MONGODB_URI=mongodb+srv://user:pass@cluster/?retryWrites=true&w=majority
MONGODB_DB=molfi
MOLFI_RPC_URL=https://testnet.hsk.xyz
MOLFI_CHAIN_ID=133
MOLFI_CONTRACTS_DIR=../molfi-contracts
PRIVATE_KEY=0xYOUR_KEEPER_ADMIN_KEY
PINATA_JWT=

# ── HSP (HashKey Settlement Protocol) ─────────────────────────────────────────
# Self-contained by default (backend acts as adapter + coordinator). To use the
# official HSP Coordinator, set these (from the organizer / hsp-hackathon docs):
HSP_COORDINATOR_URL=
HSP_API_KEY=
# Merchant that receives agent proof-fees (defaults to the protocol vault):
HSP_MERCHANT=
# Price per premium ZK proof, in mUSDC base units (6dp). Default 500000 = 0.5 mUSDC:
HSP_PROOF_PRICE=
