# ============================================
# MOLFI ENVIRONMENT VARIABLES
# ============================================
# Copy this to .env and fill in your values.

# ============================================
# HASHKEY CHAIN (EVM)
# ============================================
# Chain id: 133 = HashKey testnet, 177 = HashKey mainnet
VITE_HSK_CHAIN_ID="133"
# JSON-RPC endpoint
VITE_HSK_RPC_URL="https://testnet.hsk.xyz"
# Block explorer base URL (optional override)
VITE_HSK_EXPLORER_URL="https://testnet-explorer.hsk.xyz"

# Molfi backend API (markets, positions, ZK proofs, prices, comments)
VITE_MOLFI_API_URL="http://localhost:4000"

# ============================================
# DEPLOYED CONTRACT ADDRESSES (override defaults from deployments/133.json)
# ============================================
VITE_MUSDC_ADDRESS=""
VITE_VAULT_ADDRESS=""
VITE_ORACLE_ADDRESS=""
VITE_MARKET_ADDRESS=""
VITE_PREDICT_ESCROW_ADDRESS=""
VITE_CONFIDENTIAL_BET_ADDRESS=""
VITE_PRIVACY_POOL_ADDRESS=""
VITE_CONFIDENTIAL_BET_VERIFIER_ADDRESS=""
VITE_SOLVENCY_VERIFIER_ADDRESS=""
VITE_WITHDRAW_VERIFIER_ADDRESS=""
VITE_MUL_VERIFIER_ADDRESS=""
# confidentialBet fixed denomination (mUSDC, 6dp). 100000000 = 100 mUSDC
VITE_DENOM="100000000"
# Sample market id for the /demo page
VITE_DEMO_MARKET_ID=""

# ============================================
# SUPABASE (YOUR OWN INSTANCE)
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGci..."

# ============================================
# VENUE API KEYS (optional — multi-venue aggregation)
# ============================================
# Polymarket CLOB API
POLYMARKET_API_KEY=""
# Limitless API
LIMITLESS_API_KEY=""
