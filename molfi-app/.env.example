# Molfi app — copy to molfi-app/.env
# Targets HashKey Chain (EVM). Contract addresses mirror
# molfi-contracts/deployments/133.json (override after redeploy).

# ── HashKey Chain network ─────────────────────────────────────────────────────
# Testnet: chainId 133, RPC https://testnet.hsk.xyz
# Mainnet: chainId 177, RPC https://mainnet.hsk.xyz
VITE_HSK_CHAIN_ID=133
VITE_HSK_RPC_URL=https://testnet.hsk.xyz

# ── Molfi backend API ─────────────────────────────────────────────────────────
VITE_MOLFI_API_URL=http://localhost:4000

# ── Deployed contract addresses (molfi-contracts/deployments/133.json) ────────
# Defaults are baked in; uncomment to override.
# VITE_MUSDC_ADDRESS=0xCcCe188934316cE9ea6f8237F7e6249aB2E0C903
# VITE_MARKET_ADDRESS=0xd3f3c363CF22eD8DbAB26b9De5b12340D3816C49
# VITE_PREDICT_ESCROW_ADDRESS=0xDd5782CE36e035709b2e3F640377d3Ec6F1f1dA1
# VITE_VAULT_ADDRESS=0x6F1Bd7d424AB69B9F3689Cee208863Ce0B27f784
# VITE_ORACLE_ADDRESS=0x5439778405627512eAae2210b2584D6A9B4D517B
# VITE_CONF_BET_ADDRESS=0x6731FecE71e14155EBA0b11A116a68eA395dd14e
# VITE_PRIVACY_POOL_ADDRESS=0x4ce8970d2B0FbFd478e857F603Fc7526E0CC989a

# ── Charts (optional) ─────────────────────────────────────────────────────────
# VITE_DEEPBOOK_INDEXER_URL=

# ── Market comments (Firestore, optional) ─────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# ── Telegram alerts (optional) ────────────────────────────────────────────────
# VITE_TELEGRAM_BOT_USERNAME=YourMolfiBot

# RainbowKit / WalletConnect — get a projectId at https://cloud.walletconnect.com
# (injected wallets like MetaMask work without it; needed for WalletConnect/mobile)
VITE_WALLETCONNECT_PROJECT_ID=
