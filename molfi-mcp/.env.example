# Molfi MCP server config
MOLFI_NETWORK=testnet          # testnet (chain 133) | mainnet (chain 177)
MOLFI_API_URL=http://localhost:4000   # backend for list_markets / ZK proofs / HSP
# Treasury wallet that drips a little HSK to fresh agents for gas (fund_wallet).
# On testnet this is your deployer; on mainnet, fund this address with HSK.
MOLFI_TREASURY_KEY=0xYOUR_TREASURY_KEY
# Optional: restore a specific agent wallet on boot instead of create_wallet.
MOLFI_AGENT_KEY=
